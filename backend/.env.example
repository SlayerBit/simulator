DATABASE_URL="postgresql://USER:PASSWORD@REMOTE_DB_HOST:5432/simulator?schema=public"
JWT_SECRET="change-me"
NODE_ENV="development"
PORT="4000"

# CORS / URLs (environment-driven; do not hardcode production URLs)
FRONTEND_BASE_URL=""
BACKEND_BASE_URL=""
CORS_ALLOWED_ORIGINS=""

# Simulator safety
SIMULATOR_NAMESPACE="simulator"
ALLOWED_TARGET_NAMESPACES="simulator"
SIM_GLOBAL_KILL_SWITCH="false"
SIM_MAX_CONCURRENT="3"
SIM_MAX_DURATION_SECONDS="900"
SIM_MAX_INTENSITY_PERCENT="90"
SIM_MAX_LATENCY_MS="2000"
SIM_MAX_PACKET_LOSS_PERCENT="50"

# Grafana integration
GRAFANA_URL=""
GRAFANA_API_KEY=""
PROMETHEUS_URL=""
LOKI_URL=""

